{
  "name": "portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engineStrict": true,
  "engines": {
    "node": "24.14.0"
  },
  "scripts": {
    "format": "prettier --ignore-unknown --write . --cache",
    "fix": "eslint . --fix",
    "lint": "eslint .",
    "check": "tsc -b",
    "validate": "pnpm format && pnpm fix && pnpm lint && pnpm check",
    "dev": "vite --port 3000 --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 3000 --host",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "@tanstack/react-router": "^1.168.2",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-rough-notation": "^1.0.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0",
    "typeit-react": "^2.7.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "@tanstack/router-plugin": "^1.167.3",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-react-dom": "^3.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-react-x": "^3.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
